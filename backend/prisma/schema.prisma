generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum UserRole {
  USER
  SUPERADMIN
}

enum SubscriptionStatus {
  active
  inactive
  expired
}

enum PaymentType {
  renta
  arrear_payment
  other
}

enum ArrearStatus {
  pending
  paid
}

enum ExpenseType {
  reparacion
  repuesto
  combustible
  mantenimiento
  seguro
  impuesto
  multa
  lavado
  otro
}

// --- MODELOS ---

model User {
  id                String            @id @default(uuid())
  username          String            @unique
  email             String            @unique
  password          String
  role              UserRole          @default(USER)
  isConfirmed       Boolean           @default(false)
  confirmationToken String?
  resetToken        String?
  lastActivity      DateTime?
  createdAt         DateTime          @default(now())
  arrears           Arrear[]
  drivers           Driver[]
  expenses          Expense[]
  licenseOverrides  LicenseOverride[]
  payments          Payment[]
  subscriptions     SubscriptionKey[]
  transactions      Transaction[]
  vehicles          Vehicle[]

  @@index([email])
  @@index([username])
}

model LicenseOverride {
  id        String    @id @default(uuid())
  userId    String
  plan      String
  expiresAt DateTime?
  reason    String?
  createdBy String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SubscriptionKey {
  id             String             @id @default(uuid())
  userId         String?
  plan           String
  price          Decimal            @db.Decimal(12, 2)
  months         Int                @default(1)
  startDate      DateTime?
  dueDate        DateTime?
  status         SubscriptionStatus @default(active)
  transactionRef String?
  user           User?              @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model Transaction {
  id            String   @id @default(uuid())
  userId        String
  reference     String   @unique
  amount        Decimal  @db.Decimal(12, 2)
  plan          String
  duration      String
  status        String   @default("PENDING")
  wompiId       String?  @unique
  paymentMethod String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Driver {
  id                String    @id @default(uuid())
  userId            String
  firstName         String
  lastName          String
  email             String?
  phone             String?
  idNumber          String
  licensePhoto      String?
  idPhoto           String?
  vehicleId         String?   @unique
  deletedAt         DateTime?
  licenseExpiration DateTime?
  arrears           Arrear[]
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle           Vehicle?  @relation(fields: [vehicleId], references: [id])
  payments          Payment[]

  @@index([userId, idNumber])
  @@index([userId, deletedAt])
}

model Vehicle {
  id                          String         @id @default(uuid())
  userId                      String
  year                        Int
  licensePlate                String
  model                       String
  color                       String
  purchaseDate                DateTime?
  insurance                   String?
  insuranceNumber             String?
  soatExpiration              DateTime?
  techExpiration              DateTime?
  rentaValue                  Decimal        @db.Decimal(12, 2)
  photos                      String[]
  deletedAt                   DateTime?
  fullCoverageExpiration      DateTime?
  hasFullCoverage             Boolean?       @default(false)
  fullCoverageEmergencyNumber String?
  fullCoverageInsurer         String?
  arrears                     Arrear[]
  driver                      Driver?
  expenses                    Expense[]
  payments                    Payment[]
  user                        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, licensePlate])
  @@index([userId, deletedAt])
}

model Payment {
  id        String      @id @default(uuid())
  userId    String
  amount    Decimal     @db.Decimal(12, 2)
  date      DateTime    @default(now()) @db.Timestamptz(6)
  driverId  String
  vehicleId String
  type      PaymentType @default(renta)
  arrearId  String?
  createdAt DateTime    @default(now())
  driver    Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle   Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([driverId, vehicleId])
}

model Arrear {
  id              String       @id @default(uuid())
  userId          String
  amountOwed      Decimal      @db.Decimal(12, 2)
  status          ArrearStatus @default(pending)
  driverId        String
  vehicleId       String
  dueDate         DateTime     @db.Timestamptz(6)
  originPaymentId String?
  description     String?      // 🆕 Descripción opcional de la mora
  driver          Driver       @relation(fields: [driverId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle         Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([driverId])
}

model Expense {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String?
  amount      Decimal     @db.Decimal(12, 2)
  date        DateTime    @default(now()) @db.Timestamptz(6)
  type        ExpenseType @default(reparacion)
  mileage     Int? // 🆕 Kilometraje opcional para rastrear mantenimientos
  createdAt   DateTime    @default(now())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([userId, date])
  @@index([vehicleId, type])
}
